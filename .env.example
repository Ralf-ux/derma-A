# Supabase Configuration
# Get these values from your Supabase project dashboard:
# Settings -> API -> URL and anon key

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Admin email(s) who can access the admin panel
# Separate multiple emails with commas
EXPO_PUBLIC_ADMIN_EMAIL=
EXPO_PUBLIC_ADMIN_EMAILS=

# Optional: Gemini AI API key for real web analysis (leave empty for mock/simulation mode)
VITE_GEMINI_API_KEY=

# OpenRouter API key for DermaBot AI chat widget (https://openrouter.ai/keys)
EXPO_PUBLIC_OPENROUTER_API_KEY=

# ── Native (Expo) AI backend ──────────────────────────────────────────────────
# URL of the Python ML backend that processes skin scans on the native app.
# When running locally and testing on a physical device, use an ngrok tunnel:
#   1. Start your backend:  uvicorn main:app --host 0.0.0.0 --port 8000
#   2. Start ngrok:         ngrok http 8000
#   3. Copy the HTTPS URL from ngrok and paste it here (including /scan path)
#
# Example: EXPO_PUBLIC_BACKEND_API_URL=https://abc123.ngrok-free.app/scan
# Leave blank to use the localhost fallback (emulators only, not physical devices)
EXPO_PUBLIC_BACKEND_API_URL=

# Optional: Supabase service role key for server-side operations
# VITE_SUPABASE_SERVICE_ROLE_KEY=
